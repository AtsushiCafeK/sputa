# Google Sheets API 認証
# Google Cloud Console で作成したサービスアカウント認証ファイルのパス
GOOGLE_CREDENTIALS_JSON=../keys/service-account-key.json

# Google スプレッドシート ID
# スプレッドシート URL から取得: https://docs.google.com/spreadsheets/d/{SHEET_ID}/edit
GOOGLE_SHEET_ID=ここへスプレッドシートのIDを入力

# タイムゾーン
TIMEZONE=Asia/Tokyo

# ログレベル
LOG_LEVEL=info
